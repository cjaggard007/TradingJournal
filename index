</div><!-- /container -->

<!-- FAB -->
<button class="fab" onclick="openModal()" title="Add Trade">+</button>

<!-- TOAST -->
<div class="toast" id="toast">✓ Trade logged!</div>

<!-- ─── MODAL ─── -->
<div class="overlay" id="overlay" onclick="overlayClick(event)">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="modalTitle">Log New Trade</div>
      <div style="display:flex;align-items:center;gap:12px">
        <div class="modal-step-indicator" id="stepIndicator">Step 1 of 8</div>
        <button class="modal-close" onclick="closeModal()">✕</button>
      </div>
    </div>

    <div class="progress-track">
      <div class="progress-fill" id="progressFill" style="width:12.5%"></div>
    </div>

    <!-- STEP 1: Date -->
    <div class="step active" id="step1">
      <div class="step-question">When did this trade occur?</div>
      <div class="step-hint">Select the date of the trade</div>
      <div class="input-group">
        <label class="input-label">Date</label>
        <input class="modal-input" type="date" id="inputDate">
      </div>
      <div class="input-group">
        <label class="input-label">Week Label (auto-filled, can edit)</label>
        <input class="modal-input" type="text" id="inputWeek" placeholder="e.g. Week 1">
      </div>
    </div>

    <!-- STEP 2: Direction -->
    <div class="step" id="step2">
      <div class="step-question">What direction did you trade?</div>
      <div class="step-hint">Choose your trade direction</div>
      <div class="choices cols-3">
        <button class="choice-btn long" onclick="choose('direction','Long',this)">
          <span class="choice-icon">📈</span> Long
        </button>
        <button class="choice-btn short" onclick="choose('direction','Short',this)">
          <span class="choice-icon">📉</span> Short
        </button>
        <button class="choice-btn" onclick="choose('direction','No Trade',this)">
          <span class="choice-icon">⏸️</span> No Trade
        </button>
      </div>
    </div>

    <!-- STEP 3: Setup -->
    <div class="step" id="step3">
      <div class="step-question">What setup did you use?</div>
      <div class="step-hint">Select the trading setup</div>
      <div class="choices cols-2">
        <button class="choice-btn" onclick="choose('setup','Break and Retest',this)">
          <span class="choice-icon">🔄</span> Break & Retest
        </button>
        <button class="choice-btn" onclick="choose('setup','Bounce',this)">
          <span class="choice-icon">↩️</span> Bounce
        </button>
        <button class="choice-btn" onclick="choose('setup','Rejection',this)">
          <span class="choice-icon">🚫</span> Rejection
        </button>
        <button class="choice-btn" onclick="choose('setup','ORB',this)">
          <span class="choice-icon">⭕</span> ORB
        </button>
      </div>
      <div class="input-group" style="margin-top:8px">
        <label class="input-label">Or enter custom setup</label>
        <input class="modal-input" type="text" id="inputSetupCustom" placeholder="Custom setup name...">
      </div>
    </div>

    <!-- STEP 4: Session -->
    <div class="step" id="step4">
      <div class="step-question">Which session was this trade?</div>
      <div class="step-hint">Select the market session</div>
      <div class="choices cols-2">
        <button class="choice-btn" onclick="choose('session','NY',this)">
          <span class="choice-icon">🗽</span> New York
        </button>
        <button class="choice-btn" onclick="choose('session','London',this)">
          <span class="choice-icon">🇬🇧</span> London
        </button>
        <button class="choice-btn" onclick="choose('session','Asia',this)">
          <span class="choice-icon">🌏</span> Asia
        </button>
        <button class="choice-btn" onclick="choose('session','Pre-Market',this)">
          <span class="choice-icon">🌅</span> Pre-Market
        </button>
      </div>
    </div>

    <!-- STEP 5: Result -->
    <div class="step" id="step5">
      <div class="step-question">What was the outcome?</div>
      <div class="step-hint">Select your trade result</div>
      <div class="choices cols-2">
        <button class="choice-btn win" onclick="choose('result','Win',this)">
          <span class="choice-icon">✅</span> Win
        </button>
        <button class="choice-btn loss" onclick="choose('result','Loss',this)">
          <span class="choice-icon">❌</span> Loss
        </button>
        <button class="choice-btn be" onclick="choose('result','Break Even',this)">
          <span class="choice-icon">➡️</span> Break Even
        </button>
        <button class="choice-btn" onclick="choose('result','No Trade',this)">
          <span class="choice-icon">⏸️</span> No Trade
        </button>
      </div>
    </div>

    <!-- STEP 6: PnL & Contracts -->
    <div class="step" id="step6">
      <div class="step-question">PnL & Position Size</div>
      <div class="step-hint">Enter your profit/loss and contract count</div>
      <div class="input-group">
        <label class="input-label">PnL (USDT) — use negative for loss</label>
        <input class="modal-input" type="number" step="0.01" id="inputPnl" placeholder="e.g. +155.02 or -51.24">
      </div>
      <div class="input-row">
        <div class="input-group">
          <label class="input-label">Entry Price</label>
          <input class="modal-input" type="number" step="0.01" id="inputEntry" placeholder="e.g. 5820.50">
        </div>
        <div class="input-group">
          <label class="input-label">Exit Price</label>
          <input class="modal-input" type="number" step="0.01" id="inputExit" placeholder="e.g. 5835.25">
        </div>
      </div>
      <div class="input-group">
        <label class="input-label">Contracts</label>
        <input class="modal-input" type="number" min="1" id="inputContracts" placeholder="1" value="1">
      </div>
    </div>

    <!-- STEP 7: Notes -->
    <div class="step" id="step7">
      <div class="step-question">Trade Notes</div>
      <div class="step-hint">Add any observations, mistakes, or reminders</div>
      <div class="input-group">
        <label class="input-label">Trade Notes</label>
        <textarea class="modal-input" id="inputNotes" placeholder="e.g. London Low respected — good reaction. Exited too early."></textarea>
      </div>
    </div>

    <!-- STEP 8: Weekly Review -->
    <div class="step" id="step8">
      <div class="step-question">Weekly Review (optional)</div>
      <div class="step-hint">Record your weekly observations and lessons</div>
      <div class="input-group">
        <label class="input-label">Key Observations</label>
        <textarea class="modal-input" id="inputObservations" placeholder="What did you observe this week?" style="min-height:60px"></textarea>
      </div>
      <div class="input-group">
        <label class="input-label">Mistakes to Fix</label>
        <textarea class="modal-input" id="inputMistakes" placeholder="What did you do wrong?" style="min-height:60px"></textarea>
      </div>
      <div class="input-group">
        <label class="input-label">Next Week Focus</label>
        <textarea class="modal-input" id="inputFocus" placeholder="What will you focus on next week?" style="min-height:60px"></textarea>
      </div>
    </div>

    <!-- Footer -->
    <div class="modal-footer">
      <button class="btn-back" id="btnBack" onclick="prevStep()" style="display:none">← Back</button>
      <div style="flex:1"></div>
      <button class="btn-next" id="btnNext" onclick="nextStep()">Next →</button>
      <button class="btn-submit" id="btnSubmit" onclick="submitTrade()" style="display:none">Log Trade ✓</button>
    </div>
  </div>
</div>

<script>
// ─── STATE ───────────────────────────────────────────────────
let trades = JSON.parse(localStorage.getItem('tj_trades') || '[]');
let weeklyNotes = JSON.parse(localStorage.getItem('tj_notes') || '{}');

const TOTAL_STEPS = 8;
let currentStep = 1;
let formData = {};
let editIndex = -1; // -1 = new trade, >=0 = editing existing
let currentMode = localStorage.getItem('tj_mode') || 'paper'; // 'paper' | 'live'

// ─── MODE ────────────────────────────────────────────────────
function setMode(mode) {
  currentMode = mode;
  localStorage.setItem('tj_mode', mode);

  const isLive = mode === 'live';
  document.body.classList.toggle('live-mode', isLive);
  document.getElementById('modeBanner').classList.toggle('visible', isLive);
  document.getElementById('btnPaper').className = 'mode-btn' + (isLive ? '' : ' active-paper');
  document.getElementById('btnLive').className  = 'mode-btn' + (isLive ? ' active-live' : '');

  renderTable();
  renderStats();
  // Re-render whichever secondary tab is active
  if (document.getElementById('sec-dashboard').classList.contains('active')) renderDashboard();
  if (document.getElementById('sec-notes').classList.contains('active')) renderNotes();
}

function activeTrades() {
  return trades.filter(t => (t.mode || 'paper') === currentMode);
}

// ─── TABS ────────────────────────────────────────────────────
function switchTab(tab, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('sec-' + tab).classList.add('active');
  btn.classList.add('active');
  if (tab === 'dashboard') renderDashboard();
  if (tab === 'notes') renderNotes();
}

// ─── MODAL ───────────────────────────────────────────────────
function openModal(idx = -1) {
  editIndex = idx;
  currentStep = 1;
  formData = {};

  const isEdit = idx >= 0;
  document.getElementById('modalTitle').textContent = isEdit ? 'Edit Trade' : 'Log New Trade';
  document.getElementById('btnSubmit').textContent = isEdit ? 'Save Changes ✓' : 'Log Trade ✓';

  // Prefill values — use existing trade if editing, else defaults
  const t = isEdit ? trades[idx] : {};
  const today = new Date().toISOString().split('T')[0];

  document.getElementById('inputDate').value = t.date || today;
  document.getElementById('inputWeek').value = t.week || ('Week ' + getWeekNumber());
  document.getElementById('inputPnl').value = t.pnl !== undefined ? t.pnl : '';
  document.getElementById('inputEntry').value = t.entry || '';
  document.getElementById('inputExit').value = t.exit || '';
  document.getElementById('inputContracts').value = t.contracts || 1;
  document.getElementById('inputNotes').value = t.notes || '';
  document.getElementById('inputSetupCustom').value = '';
  document.getElementById('inputObservations').value = (weeklyNotes[t.week] || {}).observations || '';
  document.getElementById('inputMistakes').value = (weeklyNotes[t.week] || {}).mistakes || '';
  document.getElementById('inputFocus').value = (weeklyNotes[t.week] || {}).focus || '';

  // Reset then re-select choice buttons
  document.querySelectorAll('.choice-btn').forEach(b => b.classList.remove('selected'));
  if (isEdit) {
    // Pre-select matching choice buttons
    if (t.direction) preselectChoice('direction', t.direction);
    if (t.setup) {
      const matched = preselectChoice('setup', t.setup);
      if (!matched) document.getElementById('inputSetupCustom').value = t.setup;
    }
    if (t.session) preselectChoice('session', t.session);
    if (t.result) preselectChoice('result', t.result);
    // Copy all fields into formData so validation passes on steps already filled
    Object.assign(formData, t);
  }

  updateModalUI();
  document.getElementById('overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('overlay').classList.remove('open');
}

function overlayClick(e) {
  if (e.target === document.getElementById('overlay')) closeModal();
}

function getWeekNumber() {
  if (trades.length === 0) return 1;
  const lastWeek = trades[trades.length - 1].week;
  const match = lastWeek && lastWeek.match(/\d+/);
  return match ? parseInt(match[0]) : 1;
}

function updateModalUI() {
  // Show/hide steps
  for (let i = 1; i <= TOTAL_STEPS; i++) {
    document.getElementById('step' + i).classList.toggle('active', i === currentStep);
  }
  // Progress
  document.getElementById('progressFill').style.width = (currentStep / TOTAL_STEPS * 100) + '%';
  // Step indicator
  document.getElementById('stepIndicator').textContent = `Step ${currentStep} of ${TOTAL_STEPS}`;
  // Back button
  document.getElementById('btnBack').style.display = currentStep > 1 ? 'inline-flex' : 'none';
  // Next / Submit
  const isLast = currentStep === TOTAL_STEPS;
  document.getElementById('btnNext').style.display = isLast ? 'none' : 'inline-flex';
  document.getElementById('btnSubmit').style.display = isLast ? 'inline-flex' : 'none';
}

function choose(field, value, btn) {
  formData[field] = value;
  // Highlight selected
  const parent = btn.closest('.choices');
  parent.querySelectorAll('.choice-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
}

function nextStep() {
  // Validation per step
  if (currentStep === 1) {
    const d = document.getElementById('inputDate').value;
    if (!d) { shake('step1'); return; }
    formData.date = d;
    formData.week = document.getElementById('inputWeek').value || 'Week ?';
  }
  if (currentStep === 2 && !formData.direction) { shake('step2'); return; }
  if (currentStep === 3) {
    const custom = document.getElementById('inputSetupCustom').value.trim();
    if (custom) formData.setup = custom;
    if (!formData.setup) { shake('step3'); return; }
  }
  if (currentStep === 4 && !formData.session) { shake('step4'); return; }
  if (currentStep === 5 && !formData.result) { shake('step5'); return; }
  if (currentStep === 6) {
    formData.pnl = parseFloat(document.getElementById('inputPnl').value) || 0;
    formData.entry = document.getElementById('inputEntry').value || '';
    formData.exit = document.getElementById('inputExit').value || '';
    formData.contracts = parseInt(document.getElementById('inputContracts').value) || 1;
  }
  if (currentStep === 7) {
    formData.notes = document.getElementById('inputNotes').value.trim();
  }
  if (currentStep < TOTAL_STEPS) {
    currentStep++;
    updateModalUI();
  }
}

function prevStep() {
  if (currentStep > 1) { currentStep--; updateModalUI(); }
}

function shake(stepId) {
  const el = document.getElementById(stepId);
  el.style.animation = 'none';
  el.offsetHeight;
  el.style.animation = 'shake 0.3s ease';
}

// Add shake keyframes
const style = document.createElement('style');
style.textContent = `@keyframes shake { 0%,100%{transform:translateX(0)} 20%,60%{transform:translateX(-6px)} 40%,80%{transform:translateX(6px)} }`;
document.head.appendChild(style);

function preselectChoice(field, value) {
  // Find a choice button whose text content matches value and trigger choose()
  let found = false;
  document.querySelectorAll('.choice-btn').forEach(b => {
    const label = b.textContent.trim().replace(/\s+/g, ' ');
    // Match by value substring (handles emoji + label combos)
    if (label.includes(value) || value.includes(label.replace(/[^\w\s]/g, '').trim())) {
      // Only match buttons that belong to the right step
      const stepMap = { direction: 'step2', setup: 'step3', session: 'step4', result: 'step5' };
      if (b.closest('#' + stepMap[field])) {
        b.classList.add('selected');
        found = true;
      }
    }
  });
  return found;
}

function editTrade(i) {
  openModal(i);
}

function submitTrade() {
  // Collect step 8
  formData.observations = document.getElementById('inputObservations').value.trim();
  formData.mistakes = document.getElementById('inputMistakes').value.trim();
  formData.focus = document.getElementById('inputFocus').value.trim();

  // Save weekly notes
  if (formData.observations || formData.mistakes || formData.focus) {
    weeklyNotes[formData.week] = {
      observations: formData.observations,
      mistakes: formData.mistakes,
      focus: formData.focus
    };
    localStorage.setItem('tj_notes', JSON.stringify(weeklyNotes));
  }

  if (editIndex >= 0) {
    // Update existing trade (keep its original mode)
    trades[editIndex] = { ...formData, mode: trades[editIndex].mode || 'paper' };
    showToast('Trade updated successfully!');
  } else {
    // Add new trade tagged with current mode
    trades.push({ ...formData, mode: currentMode });
    showToast('Trade logged successfully!');
  }

  localStorage.setItem('tj_trades', JSON.stringify(trades));
  closeModal();
  renderTable();
  renderStats();
}

// ─── RENDER TABLE ─────────────────────────────────────────────
function renderTable() {
  const tbody = document.getElementById('tradeTable');
  const view = activeTrades();
  document.getElementById('tradeCount').textContent = view.length + ' entr' + (view.length === 1 ? 'y' : 'ies');

  if (view.length === 0) {
    tbody.innerHTML = `<tr><td colspan="13"><div class="empty-state"><div class="empty-icon">${currentMode === 'live' ? '💹' : '📈'}</div><p>No ${currentMode} trades yet. Hit the + button to log your first trade.</p></div></td></tr>`;
    return;
  }

  let cumPnl = 0;
  tbody.innerHTML = view.map((t) => {
    // Find real index in global trades array so edit/delete work correctly
    const globalIdx = trades.indexOf(t);
    cumPnl += t.pnl || 0;
    const pnl = t.pnl || 0;
    const pnlClass = pnl > 0 ? 'pnl-pos' : pnl < 0 ? 'pnl-neg' : 'pnl-zero';
    const pnlStr = pnl !== 0 ? (pnl > 0 ? '+' : '') + pnl.toFixed(2) : '—';
    const cumClass = cumPnl >= 0 ? 'pnl-pos' : 'pnl-neg';
    const cumStr = (cumPnl >= 0 ? '+' : '') + cumPnl.toFixed(2);
    const dirClass = t.direction === 'Long' ? 'dir-long' : t.direction === 'Short' ? 'dir-short' : 'dir-none';
    const resClass = t.result === 'Win' ? 'result-win' : t.result === 'Loss' ? 'result-loss' : t.result === 'Break Even' ? 'result-be' : 'result-notrade';

    return `<tr>
      <td class="date-col">${formatDate(t.date)}</td>
      <td><span class="week-badge">${t.week || '—'}</span></td>
      <td><span class="${dirClass}">${t.direction || '—'}</span></td>
      <td>${t.setup || '—'}</td>
      <td>${t.session || '—'}</td>
      <td class="${resClass}">${t.result || '—'}</td>
      <td class="${pnlClass}">${pnlStr}</td>
      <td>${t.entry || '—'}</td>
      <td>${t.exit || '—'}</td>
      <td>${t.contracts || 1}</td>
      <td class="notes-cell" title="${(t.notes||'').replace(/"/g,'&quot;')}">${t.notes || '—'}</td>
      <td class="cum-pnl ${cumClass}">${cumStr}</td>
      <td><div class="action-btns">
        <button class="edit-btn" onclick="editTrade(${globalIdx})" title="Edit trade">✏️</button>
        <button class="del-btn" onclick="deleteTrade(${globalIdx})" title="Delete trade">✕</button>
      </div></td>
    </tr>`;
  }).join('');
}

function deleteTrade(i) {
  if (confirm('Delete this trade?')) {
    trades.splice(i, 1);
    localStorage.setItem('tj_trades', JSON.stringify(trades));
    renderTable();
    renderStats();
  }
}

function formatDate(d) {
  if (!d) return '—';
  const parts = d.split('-');
  if (parts.length < 3) return d;
  return parts[2] + '/' + parts[1] + '/' + parts[0];
}

// ─── STATS ────────────────────────────────────────────────────
function renderStats() {
  const all = activeTrades();
  const actual = all.filter(t => t.result !== 'No Trade' && t.direction !== 'No Trade');
  const wins = actual.filter(t => t.result === 'Win');
  const losses = actual.filter(t => t.result === 'Loss');
  const total = actual.length;
  const cumPnl = all.reduce((s, t) => s + (t.pnl || 0), 0);
  const winRate = total > 0 ? (wins.length / total * 100).toFixed(1) : 0;
  const avgWin = wins.length > 0 ? wins.reduce((s, t) => s + t.pnl, 0) / wins.length : null;
  const avgLoss = losses.length > 0 ? losses.reduce((s, t) => s + t.pnl, 0) / losses.length : null;
  const grossWin = wins.reduce((s, t) => s + t.pnl, 0);
  const grossLoss = Math.abs(losses.reduce((s, t) => s + t.pnl, 0));
  const pf = grossLoss > 0 ? (grossWin / grossLoss).toFixed(2) : null;

  const fmt = (v, plus) => v != null ? (plus && v > 0 ? '+' : '') + v.toFixed(2) : '—';

  document.getElementById('statCumPnl').textContent = fmt(cumPnl, true);
  document.getElementById('statCumPnl').className = 'stat-value ' + (cumPnl >= 0 ? 'pos' : 'neg');
  document.getElementById('statWinRate').textContent = winRate + '%';
  document.getElementById('statTotal').textContent = total;
  document.getElementById('statAvgWin').textContent = avgWin != null ? '+' + avgWin.toFixed(2) : '—';
  document.getElementById('statAvgLoss').textContent = avgLoss != null ? avgLoss.toFixed(2) : '—';
  document.getElementById('statPF').textContent = pf ? pf + 'x' : '—';
}

// ─── DASHBOARD ────────────────────────────────────────────────
function renderDashboard() {
  const all = activeTrades();
  const actual = all.filter(t => t.result !== 'No Trade' && t.direction !== 'No Trade');
  const wins = actual.filter(t => t.result === 'Win');
  const losses = actual.filter(t => t.result === 'Loss');
  const be = actual.filter(t => t.result === 'Break Even');
  const total = actual.length;
  const cumPnl = all.reduce((s, t) => s + (t.pnl || 0), 0);
  const winRate = total > 0 ? (wins.length / total * 100).toFixed(1) : 0;
  const avgWin = wins.length > 0 ? wins.reduce((s, t) => s + t.pnl, 0) / wins.length : null;
  const avgLoss = losses.length > 0 ? losses.reduce((s, t) => s + t.pnl, 0) / losses.length : null;
  const grossWin = wins.reduce((s, t) => s + t.pnl, 0);
  const grossLoss = Math.abs(losses.reduce((s, t) => s + t.pnl, 0));
  const pf = grossLoss > 0 ? (grossWin / grossLoss).toFixed(2) + 'x' : '—';
  const best = actual.length > 0 ? Math.max(...actual.map(t => t.pnl)) : null;
  const worst = actual.length > 0 ? Math.min(...actual.map(t => t.pnl)) : null;
  const fmt = (v, plus) => v != null ? (plus && v > 0 ? '+' : '') + v.toFixed(2) : '—';

  document.getElementById('dTotal').textContent = total;
  document.getElementById('dWins').textContent = wins.length;
  document.getElementById('dLosses').textContent = losses.length;
  document.getElementById('dBE').textContent = be.length;
  document.getElementById('dWinRate').textContent = winRate + '%';
  document.getElementById('dTotalPnl').textContent = fmt(cumPnl, true);
  document.getElementById('dTotalPnl').className = 'dash-row-val ' + (cumPnl >= 0 ? 'pos' : 'neg');
  document.getElementById('dAvgWin').textContent = avgWin != null ? '+' + avgWin.toFixed(2) : '—';
  document.getElementById('dAvgLoss').textContent = avgLoss != null ? avgLoss.toFixed(2) : '—';
  document.getElementById('dBest').textContent = best != null ? '+' + best.toFixed(2) : '—';
  document.getElementById('dWorst').textContent = worst != null ? worst.toFixed(2) : '—';
  document.getElementById('dPF').textContent = pf;

  // Session bars
  const sessions = ['NY', 'London', 'Asia', 'Pre-Market'];
  document.getElementById('sessionBars').innerHTML = sessions.map(s => {
    const st = actual.filter(t => t.session === s);
    const sw = st.filter(t => t.result === 'Win').length;
    const wr = st.length > 0 ? Math.round(sw / st.length * 100) : 0;
    return barItem(s, wr, st.length, 'cyan');
  }).join('');

  // Setup bars
  const setups = ['Break and Retest', 'Bounce', 'Rejection', 'ORB'];
  const allSetups = [...new Set(actual.map(t => t.setup).filter(Boolean))];
  const allSetupsList = [...new Set([...setups, ...allSetups])];
  document.getElementById('setupBars').innerHTML = allSetupsList.map(s => {
    const st = actual.filter(t => t.setup === s);
    const sw = st.filter(t => t.result === 'Win').length;
    const wr = st.length > 0 ? Math.round(sw / st.length * 100) : 0;
    return barItem(s, wr, st.length, 'gold');
  }).join('');

  // Weekly table
  const weeks = [...new Set(all.map(t => t.week).filter(Boolean))];
  const tbody = document.getElementById('weeklyTable');
  if (weeks.length === 0) {
    tbody.innerHTML = `<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;font-size:12px;">No data yet</td></tr>`;
    return;
  }

  tbody.innerHTML = weeks.map(w => {
    const wt = all.filter(t => t.week === w && t.result !== 'No Trade' && t.direction !== 'No Trade');
    const ww = wt.filter(t => t.result === 'Win');
    const wl = wt.filter(t => t.result === 'Loss');
    const wtPnl = wt.reduce((s, t) => s + (t.pnl || 0), 0);
    const avgPnl = wt.length > 0 ? wtPnl / wt.length : 0;
    const bestW = wt.length > 0 ? Math.max(...wt.map(t => t.pnl || 0)) : null;
    const wr = wt.length > 0 ? (ww.length / wt.length * 100).toFixed(1) : 0;
    const pnlClass = wtPnl >= 0 ? 'pnl-pos' : 'pnl-neg';
    return `<tr>
      <td style="font-weight:700;color:var(--text)">${w}</td>
      <td>${wt.length}</td>
      <td style="color:var(--green)">${ww.length}</td>
      <td style="color:var(--red)">${wl.length}</td>
      <td style="color:var(--cyan)">${wr}%</td>
      <td class="${pnlClass}">${(wtPnl >= 0 ? '+' : '') + wtPnl.toFixed(2)}</td>
      <td style="color:var(--text-dim)">${(avgPnl >= 0 ? '+' : '') + avgPnl.toFixed(2)}</td>
      <td style="color:var(--green)">${bestW != null ? '+' + bestW.toFixed(2) : '—'}</td>
    </tr>`;
  }).join('');
}

function barItem(label, wr, count, color) {
  return `<div class="bar-item">
    <div class="bar-label"><span>${label}</span><span>${wr}% (${count} trades)</span></div>
    <div class="bar-track"><div class="bar-fill ${color}" style="width:${wr}%"></div></div>
  </div>`;
}

// ─── NOTES ────────────────────────────────────────────────────
function renderNotes() {
  const weeks = [...new Set(activeTrades().map(t => t.week).filter(Boolean))];
  const grid = document.getElementById('notesGrid');

  if (weeks.length === 0) {
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">📝</div><p>No weekly notes yet. Add trades and reviews to see them here.</p></div>`;
    return;
  }

  grid.innerHTML = weeks.map(w => {
    const n = weeklyNotes[w] || {};
    return `<div class="notes-card">
      <div class="notes-week-tag">📅 ${w}</div>
      <div class="notes-section-label">🔭 Key Observations</div>
      <div class="notes-text observations">${n.observations || '<span style="color:var(--text-muted)">No observations recorded.</span>'}</div>
      <div class="notes-section-label">⚠️ Mistakes to Fix</div>
      <div class="notes-text mistakes">${n.mistakes || '<span style="color:var(--text-muted)">No mistakes recorded.</span>'}</div>
      <div class="notes-section-label">🎯 Next Week Focus</div>
      <div class="notes-text focus">${n.focus || '<span style="color:var(--text-muted)">No focus set.</span>'}</div>
    </div>`;
  }).join('');
}

// ─── TOAST ────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = '✓ ' + msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ─── INIT ─────────────────────────────────────────────────────
setMode(currentMode);
</script>
</body>
</html>
