<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Trading Journal — Micro S&P 500</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080d1a;
    --bg2: #0d1526;
    --bg3: #111c30;
    --surface: #0f1d35;
    --surface2: #162440;
    --border: #1e3050;
    --border2: #243a5e;
    --cyan: #00d4ff;
    --cyan-dim: rgba(0,212,255,0.15);
    --cyan-glow: rgba(0,212,255,0.3);
    --gold: #f5c542;
    --gold-dim: rgba(245,197,66,0.15);
    --green: #00e676;
    --green-dim: rgba(0,230,118,0.12);
    --red: #ff4d6d;
    --red-dim: rgba(255,77,109,0.12);
    --text: #e8f4f8;
    --text-dim: #6b8aaa;
    --text-muted: #3d5a7a;
    --radius: 10px;
    --radius-sm: 6px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background grid */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 24px;
    position: relative;
    z-index: 1;
  }

  /* ─── HEADER ─── */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .header-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--cyan), #0077ff);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    box-shadow: 0 0 24px var(--cyan-glow);
  }

  header h1 {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--text);
  }

  header h1 span {
    color: var(--cyan);
  }

  .header-subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 2px;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .tab-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 8px 18px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }

  .tab-btn:hover, .tab-btn.active {
    background: var(--cyan-dim);
    border-color: var(--cyan);
    color: var(--cyan);
  }

  /* ─── STATS STRIP ─── */
  .stats-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
    margin-bottom: 28px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 18px;
    transition: border-color 0.2s;
  }

  .stat-card:hover { border-color: var(--border2); }

  .stat-card.highlight {
    border-color: var(--cyan);
    background: linear-gradient(135deg, var(--surface), rgba(0,212,255,0.05));
    box-shadow: 0 0 20px rgba(0,212,255,0.08);
  }

  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .stat-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 22px;
    font-weight: 600;
    line-height: 1;
  }

  .stat-value.pos { color: var(--green); }
  .stat-value.neg { color: var(--red); }
  .stat-value.cyan { color: var(--cyan); }
  .stat-value.gold { color: var(--gold); }
  .stat-value.white { color: var(--text); }

  /* ─── SECTIONS ─── */
  .section { display: none; }
  .section.active { display: block; }

  /* ─── TABLE ─── */
  .table-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .table-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .table-title::before {
    content: '';
    width: 3px;
    height: 16px;
    background: var(--cyan);
    border-radius: 2px;
    box-shadow: 0 0 8px var(--cyan);
  }

  .table-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead th {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--cyan);
    background: var(--bg3);
    padding: 14px 16px;
    text-align: left;
    white-space: nowrap;
    border-bottom: 1px solid var(--border);
  }

  thead th:last-child { text-align: right; }

  tbody tr {
    border-bottom: 1px solid rgba(30,48,80,0.5);
    transition: background 0.15s;
    animation: rowIn 0.3s ease;
  }

  @keyframes rowIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  tbody tr:hover { background: rgba(0,212,255,0.03); }
  tbody tr:last-child { border-bottom: none; }

  tbody td {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    padding: 13px 16px;
    color: var(--text-dim);
    white-space: nowrap;
  }

  td.date-col { color: var(--text); font-weight: 500; }

  .week-badge {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 1px;
  }

  .dir-long {
    color: var(--green);
    background: var(--green-dim);
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
  }

  .dir-short {
    color: var(--red);
    background: var(--red-dim);
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
  }

  .dir-none {
    color: var(--text-muted);
    background: rgba(61,90,122,0.2);
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 11px;
  }

  .result-win {
    color: var(--green);
    font-weight: 600;
  }

  .result-loss {
    color: var(--red);
    font-weight: 600;
  }

  .result-be {
    color: var(--gold);
    font-weight: 600;
  }

  .result-notrade {
    color: var(--text-muted);
  }

  .pnl-pos { color: var(--green); font-weight: 600; }
  .pnl-neg { color: var(--red); font-weight: 600; }
  .pnl-zero { color: var(--text-muted); }

  td.cum-pnl {
    text-align: right;
    font-weight: 600;
  }

  .notes-cell {
    max-width: 220px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-muted);
    font-size: 11px;
  }

  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-muted);
  }

  .empty-state .empty-icon { font-size: 40px; margin-bottom: 12px; }
  .empty-state p { font-size: 14px; }

  /* ─── DASHBOARD ─── */
  .dashboard-grid {
    display: grid;
    grid-template-columns: 280px 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }

  .dash-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
  }

  .dash-card-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .dash-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 9px 0;
    border-bottom: 1px solid rgba(30,48,80,0.4);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
  }

  .dash-row:last-child { border-bottom: none; }

  .dash-row-label { color: var(--text-dim); }
  .dash-row-val { font-weight: 600; }

  .bar-wrap {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .bar-item { display: flex; flex-direction: column; gap: 5px; }

  .bar-label {
    display: flex;
    justify-content: space-between;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-dim);
  }

  .bar-track {
    height: 6px;
    background: var(--bg3);
    border-radius: 3px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--cyan), #0077ff);
    transition: width 0.8s cubic-bezier(0.4,0,0.2,1);
  }

  .bar-fill.gold { background: linear-gradient(90deg, var(--gold), #ff9800); }
  .bar-fill.green { background: linear-gradient(90deg, var(--green), #00bfa5); }

  /* Weekly Table */
  .weekly-table {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .weekly-table table thead th {
    background: var(--bg3);
  }

  .weekly-table table tbody td {
    font-size: 13px;
  }

  /* ─── NOTES ─── */
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }

  .notes-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    transition: border-color 0.2s;
  }

  .notes-card:hover { border-color: var(--border2); }

  .notes-week-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 14px;
  }

  .notes-section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 5px;
    margin-top: 12px;
  }

  .notes-text {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.6;
  }

  .notes-text.observations { color: var(--text); }
  .notes-text.mistakes { color: var(--red); opacity: 0.8; }
  .notes-text.focus { color: var(--gold); opacity: 0.9; }

  /* ─── FAB ─── */
  .fab {
    position: fixed;
    bottom: 32px;
    right: 32px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--cyan), #0077ff);
    border: none;
    color: #000;
    font-size: 28px;
    font-weight: 300;
    cursor: pointer;
    box-shadow: 0 0 30px var(--cyan-glow), 0 8px 32px rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    transition: transform 0.2s, box-shadow 0.2s;
    line-height: 1;
  }

  .fab:hover {
    transform: scale(1.1) rotate(90deg);
    box-shadow: 0 0 50px rgba(0,212,255,0.5), 0 8px 32px rgba(0,0,0,0.5);
  }

  /* ─── MODAL OVERLAY ─── */
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(4,8,20,0.85);
    backdrop-filter: blur(6px);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }

  .overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  /* ─── MODAL ─── */
  .modal {
    background: var(--bg2);
    border: 1px solid var(--border2);
    border-radius: 16px;
    width: 520px;
    max-width: 95vw;
    padding: 32px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6), 0 0 60px rgba(0,212,255,0.06);
    transform: translateY(20px) scale(0.97);
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
  }

  .overlay.open .modal {
    transform: translateY(0) scale(1);
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .modal-title {
    font-size: 18px;
    font-weight: 800;
    color: var(--text);
  }

  .modal-step-indicator {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 1px;
  }

  .modal-close {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 22px;
    cursor: pointer;
    line-height: 1;
    padding: 4px;
    transition: color 0.2s;
  }

  .modal-close:hover { color: var(--red); }

  /* Progress bar */
  .progress-track {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    margin-bottom: 28px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--cyan), #0077ff);
    border-radius: 2px;
    transition: width 0.4s ease;
    box-shadow: 0 0 8px var(--cyan-glow);
  }

  /* Step */
  .step { display: none; }
  .step.active { display: block; animation: stepIn 0.25s ease; }

  @keyframes stepIn {
    from { opacity: 0; transform: translateX(12px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .step-question {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }

  .step-hint {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  /* Choice grid */
  .choices {
    display: grid;
    gap: 10px;
    margin-bottom: 24px;
  }

  .choices.cols-2 { grid-template-columns: 1fr 1fr; }
  .choices.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
  .choices.cols-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }

  .choice-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 14px 12px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .choice-btn .choice-icon { font-size: 20px; }
  .choice-btn:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    background: var(--cyan-dim);
  }

  .choice-btn.selected {
    border-color: var(--cyan);
    color: var(--cyan);
    background: var(--cyan-dim);
    box-shadow: 0 0 12px rgba(0,212,255,0.15);
  }

  .choice-btn.long:hover, .choice-btn.long.selected {
    border-color: var(--green);
    color: var(--green);
    background: var(--green-dim);
    box-shadow: 0 0 12px rgba(0,230,118,0.15);
  }

  .choice-btn.short:hover, .choice-btn.short.selected {
    border-color: var(--red);
    color: var(--red);
    background: var(--red-dim);
    box-shadow: 0 0 12px rgba(255,77,109,0.15);
  }

  .choice-btn.win:hover, .choice-btn.win.selected {
    border-color: var(--green);
    color: var(--green);
    background: var(--green-dim);
  }

  .choice-btn.loss:hover, .choice-btn.loss.selected {
    border-color: var(--red);
    color: var(--red);
    background: var(--red-dim);
  }

  .choice-btn.be:hover, .choice-btn.be.selected {
    border-color: var(--gold);
    color: var(--gold);
    background: var(--gold-dim);
  }

  /* Input */
  .input-group {
    margin-bottom: 16px;
  }

  .input-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 7px;
    display: block;
  }

  .modal-input {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    padding: 12px 14px;
    outline: none;
    transition: border-color 0.2s;
  }

  .modal-input:focus {
    border-color: var(--cyan);
    box-shadow: 0 0 0 3px rgba(0,212,255,0.08);
  }

  textarea.modal-input {
    resize: vertical;
    min-height: 80px;
    font-size: 13px;
    font-family: 'Syne', sans-serif;
  }

  .input-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  /* Modal footer */
  .modal-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 8px;
  }

  .btn-back {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 11px 22px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-back:hover { border-color: var(--border2); color: var(--text); }

  .btn-next {
    background: linear-gradient(135deg, var(--cyan), #0077ff);
    border: none;
    color: #000;
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    padding: 11px 28px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }

  .btn-next:hover { box-shadow: 0 0 20px var(--cyan-glow); transform: translateY(-1px); }

  .btn-next:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }

  .btn-submit {
    background: linear-gradient(135deg, var(--green), #00bfa5);
    border: none;
    color: #000;
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    padding: 11px 28px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-submit:hover { box-shadow: 0 0 20px rgba(0,230,118,0.3); transform: translateY(-1px); }

  /* ─── Toast ─── */
  .toast {
    position: fixed;
    bottom: 110px;
    right: 32px;
    background: var(--surface2);
    border: 1px solid var(--green);
    color: var(--green);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    padding: 12px 20px;
    border-radius: var(--radius-sm);
    z-index: 300;
    box-shadow: 0 0 20px rgba(0,230,118,0.15);
    transform: translateY(20px);
    opacity: 0;
    transition: all 0.3s;
    pointer-events: none;
  }

  .toast.show { transform: translateY(0); opacity: 1; }

  /* ─── Action buttons ─── */
  .action-btns { display: flex; gap: 4px; justify-content: flex-end; }

  .del-btn, .edit-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 13px;
    padding: 3px 7px;
    border-radius: 4px;
    transition: all 0.15s;
    color: var(--text-muted);
  }

  .del-btn:hover { color: var(--red); background: var(--red-dim); }

  .edit-btn:hover { color: var(--cyan); background: var(--cyan-dim); }

  /* ─── Mode Toggle ─── */
  .mode-toggle {
    display: flex;
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 50px;
    padding: 4px;
    gap: 2px;
    position: relative;
  }

  .mode-btn {
    background: none;
    border: none;
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 700;
    padding: 7px 16px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  .mode-btn.active-paper {
    background: rgba(0,212,255,0.15);
    color: var(--cyan);
    box-shadow: 0 0 12px rgba(0,212,255,0.1);
  }

  .mode-btn.active-live {
    background: rgba(255,77,109,0.18);
    color: var(--red);
    box-shadow: 0 0 12px rgba(255,77,109,0.15);
  }

  /* Live mode — subtle red tint on the header border */
  body.live-mode header {
    border-bottom-color: rgba(255,77,109,0.3);
  }

  body.live-mode .header-icon {
    background: linear-gradient(135deg, var(--red), #c0003c);
    box-shadow: 0 0 24px rgba(255,77,109,0.35);
  }

  /* Mode banner strip */
  .mode-banner {
    display: none;
    align-items: center;
    gap: 10px;
    background: rgba(255,77,109,0.08);
    border: 1px solid rgba(255,77,109,0.25);
    border-radius: var(--radius-sm);
    padding: 9px 16px;
    margin-bottom: 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--red);
    letter-spacing: 1px;
    animation: fadeSlideIn 0.3s ease;
  }

  .mode-banner.visible { display: flex; }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--red);
    box-shadow: 0 0 8px var(--red);
    animation: pulse-dot 1.2s infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.75); }
  }

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .stats-strip { grid-template-columns: repeat(3, 1fr); }
    .dashboard-grid { grid-template-columns: 1fr; }
    .tab-btn span { display: none; }
  }

  @media (max-width: 600px) {
    .stats-strip { grid-template-columns: repeat(2, 1fr); }
    header { flex-wrap: wrap; gap: 16px; }
  }
</style>
</head>
<body>

<div class="container">

  <!-- HEADER -->
  <header>
    <div class="header-left">
      <div class="header-icon">⚡</div>
      <div>
        <h1>Trading Journal — <span>Micro S&P 500</span></h1>
        <div class="header-subtitle">ES1! · New York · Real-Time Performance</div>
      </div>
    </div>
    <div class="header-right">
      <div class="mode-toggle" title="Switch trading mode">
        <button class="mode-btn active-paper" id="btnPaper" onclick="setMode('paper')">📋 Paper</button>
        <button class="mode-btn" id="btnLive" onclick="setMode('live')">🔴 Live</button>
      </div>
      <button class="tab-btn active" onclick="switchTab('journal', this)">📋 <span>Journal</span></button>
      <button class="tab-btn" onclick="switchTab('dashboard', this)">📊 <span>Dashboard</span></button>
      <button class="tab-btn" onclick="switchTab('notes', this)">📝 <span>Notes</span></button>
    </div>
  </header>

  <!-- LIVE MODE BANNER -->
  <div class="mode-banner" id="modeBanner">
    <div class="live-dot"></div>
    LIVE TRADING MODE — Real money on the line. Trade with discipline.
  </div>

  <!-- STATS STRIP -->
  <div class="stats-strip" id="statsStrip">
    <div class="stat-card highlight">
      <div class="stat-label">Cum PnL</div>
      <div class="stat-value pos" id="statCumPnl">+0.00</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Win Rate</div>
      <div class="stat-value cyan" id="statWinRate">0.0%</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total Trades</div>
      <div class="stat-value white" id="statTotal">0</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Avg Win</div>
      <div class="stat-value pos" id="statAvgWin">—</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Avg Loss</div>
      <div class="stat-value neg" id="statAvgLoss">—</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Profit Factor</div>
      <div class="stat-value gold" id="statPF">—</div>
    </div>
  </div>

  <!-- ─── JOURNAL SECTION ─── -->
  <div class="section active" id="sec-journal">
    <div class="table-header">
      <div class="table-title">Trade Log</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-muted);" id="tradeCount">0 entries</div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Week</th>
            <th>Direction</th>
            <th>Setup</th>
            <th>Session</th>
            <th>Result</th>
            <th>PnL (USDT)</th>
            <th>Entry</th>
            <th>Exit</th>
            <th>Contracts</th>
            <th>Notes</th>
            <th>Cum PnL</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="tradeTable">
          <tr>
            <td colspan="13">
              <div class="empty-state">
                <div class="empty-icon">📈</div>
                <p>No trades yet. Hit the + button to log your first trade.</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ─── DASHBOARD SECTION ─── -->
  <div class="section" id="sec-dashboard">
    <div class="dashboard-grid">
      <!-- Overall Stats -->
      <div class="dash-card">
        <div class="dash-card-title">🏆 Overall Stats</div>
        <div class="dash-row"><span class="dash-row-label">Total Trades</span><span class="dash-row-val white" id="dTotal">0</span></div>
        <div class="dash-row"><span class="dash-row-label">Wins</span><span class="dash-row-val pos" id="dWins">0</span></div>
        <div class="dash-row"><span class="dash-row-label">Losses</span><span class="dash-row-val neg" id="dLosses">0</span></div>
        <div class="dash-row"><span class="dash-row-label">Break Evens</span><span class="dash-row-val gold" id="dBE">0</span></div>
        <div class="dash-row"><span class="dash-row-label">Win Rate</span><span class="dash-row-val cyan" id="dWinRate">0%</span></div>
        <div class="dash-row"><span class="dash-row-label">Total PnL</span><span class="dash-row-val pos" id="dTotalPnl">+0.00</span></div>
        <div class="dash-row"><span class="dash-row-label">Avg Win</span><span class="dash-row-val pos" id="dAvgWin">—</span></div>
        <div class="dash-row"><span class="dash-row-label">Avg Loss</span><span class="dash-row-val neg" id="dAvgLoss">—</span></div>
        <div class="dash-row"><span class="dash-row-label">Best Trade</span><span class="dash-row-val pos" id="dBest">—</span></div>
        <div class="dash-row"><span class="dash-row-label">Worst Trade</span><span class="dash-row-val neg" id="dWorst">—</span></div>
        <div class="dash-row"><span class="dash-row-label">Profit Factor</span><span class="dash-row-val gold" id="dPF">—</span></div>
      </div>

      <!-- Win Rate by Session -->
      <div class="dash-card">
        <div class="dash-card-title">🕐 Win Rate by Session</div>
        <div class="bar-wrap" id="sessionBars"></div>
      </div>

      <!-- Win Rate by Setup -->
      <div class="dash-card">
        <div class="dash-card-title">⚡ Win Rate by Setup</div>
        <div class="bar-wrap" id="setupBars"></div>
      </div>
    </div>

    <!-- Weekly Breakdown -->
    <div class="weekly-table">
      <table>
        <thead>
          <tr>
            <th>Week</th>
            <th>Trades</th>
            <th>Wins</th>
            <th>Losses</th>
            <th>Win Rate</th>
            <th>Total PnL</th>
            <th>Avg PnL</th>
            <th>Best Trade</th>
          </tr>
        </thead>
        <tbody id="weeklyTable"></tbody>
